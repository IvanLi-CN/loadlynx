{
  "name": "loadlynx-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/write-version.mjs && bun scripts/ports.ts check webDev && vite",
    "build": "tsc -b && vite build && node scripts/write-version.mjs",
    "check:bundle": "bun scripts/check-bundles.ts all",
    "check:bundle:app": "bun scripts/check-bundles.ts app",
    "check:bundle:storybook": "bun scripts/check-bundles.ts storybook",
    "test:unit": "vitest --config vitest.config.ts --project=unit --run",
    "test:e2e": "node scripts/run-playwright.mjs test",
    "test:e2e:ui": "node scripts/run-playwright.mjs test --ui",
    "storybook": "STORYBOOK_PORT=$(bun scripts/ports.ts print storybook) && storybook dev -p $STORYBOOK_PORT --exact-port",
    "build-storybook": "storybook build",
    "test:storybook": "vitest --config vitest.config.ts --project=storybook",
    "test:storybook:ci": "bun run build-storybook --quiet && bun run check:bundle:storybook && vitest --config vitest.config.ts --project=storybook --run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "preview": "bun scripts/ports.ts check webPreview && vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.71.10",
    "@tanstack/react-router": "1.139.14",
    "@tanstack/react-router-devtools": "1.139.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "esptool-js": "^0.6.0",
    "i18next": "^26.3.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-vitest": "10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query-devtools": "^5.71.10",
    "@vitest/browser": "^3.2.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "lefthook": "^2.0.4",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "storybook": "^10.4.2",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
