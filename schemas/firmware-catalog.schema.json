{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loadlynx.local/schemas/firmware-catalog.schema.json",
  "title": "LoadLynx Firmware Catalog",
  "type": "object",
  "required": ["schema_version", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "artifact_id",
        "name",
        "target",
        "package_version",
        "git_sha",
        "build_id",
        "build_profile",
        "features",
        "protocol",
        "defmt",
        "files"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "enum": ["digital_esp32s3", "analog_stm32g431"]
        },
        "package_version": {
          "type": "string",
          "minLength": 1
        },
        "git_sha": {
          "type": "string",
          "minLength": 1
        },
        "build_id": {
          "type": "string",
          "minLength": 1
        },
        "build_profile": {
          "type": "string",
          "minLength": 1
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "protocol": {
          "type": "string",
          "minLength": 1
        },
        "defmt": {
          "type": "object",
          "required": ["enabled", "encoding"],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "encoding": {
              "type": "string"
            },
            "elf_sha256": {
              "type": ["string", "null"],
              "pattern": "^[a-f0-9]{64}$"
            },
            "table_sha256": {
              "type": ["string", "null"],
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/file"
          }
        }
      }
    },
    "file": {
      "type": "object",
      "required": ["kind", "path", "sha256", "size"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": ["image", "elf", "manifest", "metadata"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "flash_address": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    }
  }
}
